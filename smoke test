name: Smoke Test

# Runs automatically — no manual steps required once this file is in your repo.
#   - on every push, to any branch
#   - on every pull request
#   - "workflow_dispatch" also lets you trigger it manually from the GitHub
#     Actions tab if you ever want to re-run it without a new push
on:
  push:
    branches: [ "**" ]
  pull_request:
    branches: [ "**" ]
  workflow_dispatch: {}

jobs:
  smoke-test:
    runs-on: ubuntu-latest
    timeout-minutes: 10

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.12"

      - name: Install app dependencies
        run: |
          python -m pip install --upgrade pip
          pip install -r requirements.txt

      - name: Install test dependencies
        run: pip install pytest

      - name: Generate fixture scan data (fake data, never touches real scans)
        run: python tests/make_fixture.py

      - name: Run smoke test suite
        run: pytest tests/test_smoke_app.py -v
